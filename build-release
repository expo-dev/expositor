RUSTFLAGS='-C target-feature=+popcnt,+lzcnt,+avx,+bmi1,-bmi2,-avx2' cargo build --target x86_64-unknown-linux-gnu --release
RUSTFLAGS='-C target-feature=+popcnt,+lzcnt,+avx,+bmi1,-bmi2,-avx2' cargo build --target x86_64-pc-windows-gnu    --release
mv target/x86_64-unknown-linux-gnu/release/expositor  release/linux/amd/generic/expo-$VERSION-amd-avx+bmi
mv target/x86_64-pc-windows-gnu/release/expositor.exe release/windows/amd/generic/expo-$VERSION-amd-avx+bmi.exe

# Generic AMD (up to AVX2)
RUSTFLAGS='-C target-feature=+popcnt,+lzcnt,+avx,+bmi1,+bmi2,+avx2' cargo build --target x86_64-unknown-linux-gnu --release
RUSTFLAGS='-C target-feature=+popcnt,+lzcnt,+avx,+bmi1,+bmi2,+avx2' cargo build --target x86_64-pc-windows-gnu    --release
mv target/x86_64-unknown-linux-gnu/release/expositor  release/linux/amd/generic/expo-$VERSION-amd-avx2
mv target/x86_64-pc-windows-gnu/release/expositor.exe release/windows/amd/generic/expo-$VERSION-amd-avx2.exe

rm -r target

cd release
zip -vr linux-binaries.zip linux
zip -vr windows-binaries.zip windows
tar -cvzf linux-binaries.tar.gz linux
tar -cvzf windows-binaries.tar.gz windows

rm -r linux
rm -r windows
