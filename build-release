#! /usr/bin/env sh

if [ $# -ne 1 ]; then
  echo "usage: $0 <version>"
  exit
fi
export VERSION="$1"

BUILD_DATE=$(date +"%-d %b %Y")
BUILD_TIME=$(date +"%H%M")
export BUILD="$BUILD_TIME on $BUILD_DATE"

